{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "fonts": {
    "family": "Inter"
  },
  "background": {
    "decoration": "grid"
  },
  "redirects": [
    {
      "source": "/",
      "destination": "/platform/quickstart"
    }
  ],
  "appearance": {
    "default": "dark",
    "strict": true
  },

  "name": "Aurora Docs",
  "description": "",
  "colors": {
    "primary": "#ff2525",
    "light": "#ff5454",
    "dark": "#cc0b0b"
  },
  "favicon": "/assets/logo/aurora.svg",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Discord",
          "icon": "discord",
          "href": "https://discord.gg/projectaurora"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Get Started",
        "icon" : "sparkles",
        "expanded": true,
        "pages": [
          "start/introduction",
          "start/scripts",
          "start/executors",
          "start/features"
        ]
      },
      {
        "group": "License",
        "icon": "key",
        "expanded": true,
        "pages": [
          "license/premium",
          "license/keysys"
        ]
      }
    ]
  },
  "logo": {
    "light": "/assets/logo/aurora.svg",
    "dark": "/assets/logo/aurora.svg",
    "height": 20
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/projectaurora"
    }
  }
}
